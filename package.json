{
  "name": "thecreativereview",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude 'tests/**/*.integration.test.ts'",
    "test:watch": "vitest --exclude 'tests/**/*.integration.test.ts'",
    "test:integration": "vitest run tests/integration/",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset && npm run db:seed",
    "db:seed": "tsx scripts/seed.ts",
    "db:types": "supabase gen types typescript --local > lib/database.types.ts",
    "worker:digest": "tsx workers/digest.ts"
  },
  "dependencies": {
    "@amplitude/analytics-node": "^1.5.54",
    "@base-ui/react": "^1.4.0",
    "@next/third-parties": "^16.2.4",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "@sentry/nextjs": "^10.49.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.0",
    "shadcn": "^4.3.0",
    "stripe": "^22.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
