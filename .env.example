# --- Supabase -----------------------------------------------------------------
# Project URL + anon key from the Supabase dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Service role key — bypasses RLS. NEVER commit. Used only for:
#   - local seed script
#   - signup workspace bootstrap
#   - Railway cron worker (milestone 4)
#   - Stripe webhook handler (milestone 4)
SUPABASE_SERVICE_ROLE_KEY=""

# --- App ----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Sentry -------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# --- Resend (milestone 4) -----------------------------------------------------
RESEND_API_KEY=""

# --- Stripe (milestone 4) -----------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
