# --- Supabase -----------------------------------------------------------------
# Project URL + anon key from the Supabase dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Service role key — bypasses RLS. NEVER commit. Used only for:
#   - local seed script
#   - signup workspace bootstrap
#   - Railway cron worker (milestone 4)
#   - Stripe webhook handler (milestone 4)
SUPABASE_SERVICE_ROLE_KEY=""

# --- App ----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# What anonymous `/` visitors see: 'waitlist' (pre-launch form) or 'live'
# (full marketing). Defaults to 'waitlist' when unset. Flip to 'live' on
# Railway at launch — no code deploy needed.
NEXT_PUBLIC_LAUNCH_MODE="waitlist"

# --- Sentry -------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# --- Resend -------------------------------------------------------------------
# API key from https://resend.com → API Keys.
RESEND_API_KEY=""
# Sender address for transactional email. Must be on a Resend-verified domain
# for delivery to anyone other than your signed-up address. Defaults to
# "Creative Review <onboarding@resend.dev>" if unset (sandbox-only).
EMAIL_FROM=""

# --- Stripe (milestone 4) -----------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Optional per-plan price ID overrides. Leave unset to use the committed
# test-mode defaults in lib/stripe/config.ts. Set on Railway for live mode,
# or for adding test tiers without a code commit.
STRIPE_PRICE_SOLO=""
STRIPE_PRICE_STUDIO=""
STRIPE_PRICE_AGENCY=""
